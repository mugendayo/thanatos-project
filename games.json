{
  "_meta": {
    "schema_version": "1.1.0",
    "created_at": "2026-03-25",
    "updated_at": "2026-03-25",
    "description": "ThanatosGames ワールドマップ 公式データスキーマ",
    "note": "ui_display は公開面。internal_only は Notion 等の内部管理専用。null = 未確認・未入力。"
  },

  "schema_template": {
    "game_id": "STRING — 例: gachi_bunkasai（スネークケース・英字）",
    "ui_display": {
      "title":      "STRING — ゲームタイトル（正式名称）",
      "tagline":    "STRING — キャッチコピー（30字以内推奨）",
      "tags":       ["STRING — ジャンルタグ（例: LARP, 宿泊型, カードゲーム）"],
      "target":     ["STRING — 参加してほしい人物像（箇条書き、各15字以内）"],
      "summary":    "STRING — 概要（80字以内。一目で魅力が伝わる文）",
      "outcome":    "STRING — 体験するとどうなるか（感情・変化を中心に）",
      "venue": {
        "display_name": "STRING — 表示名（例: 大阪・淀川河川敷）",
        "region":       "STRING — 地域タグ（例: 大阪, 北海道, 海外）"
      },
      "next_event": {
        "date":  "STRING | null — 例: 2026-08-00（未定の場合 null）",
        "label": "STRING | null — 例: 夏開催予定"
      },
      "reviews": [
        {
          "body":     "STRING — 口コミ本文（60字以内推奨）",
          "author":   "STRING | null — 例: 20代 社会人",
          "verified": "BOOLEAN — 実参加者確認済みか"
        }
      ],
      "latest_news": {
        "date": "STRING | null — 例: 2026-03-20",
        "body": "STRING | null — 最新情報・告知（100字以内）"
      },
      "recent_update": {
        "date": "STRING | null",
        "body": "STRING | null — 最近のアップデート"
      }
    },
    "internal_only": {
      "status":    "ENUM — draft | active | paused | archived",
      "price": {
        "amount": "NUMBER | null — 参加費（円）",
        "note":   "STRING | null — 例: 食材費込み、早割あり"
      },
      "capacity": {
        "min": "NUMBER | null — 最小催行人数",
        "max": "NUMBER | null — 定員"
      },
      "apply_url": "STRING | null — 申込フォームURL",
      "events": [
        {
          "date":      "STRING — 開催日",
          "venue":     "STRING — 開催場所",
          "headcount": "NUMBER | null — 参加人数",
          "revenue":   "NUMBER | null — 売上（円）",
          "cost":      "NUMBER | null — 経費（円）",
          "memo":      "STRING | null — 振り返りメモ"
        }
      ],
      "kpi": {
        "target_headcount_per_year": "NUMBER | null — 年間目標参加者数",
        "target_revenue_per_event":  "NUMBER | null — 1回あたり目標売上（円）",
        "notes":                     "STRING | null"
      },
      "updates": [
        {
          "date": "STRING — 更新日",
          "body": "STRING — 変更内容メモ"
        }
      ]
    }
  },

